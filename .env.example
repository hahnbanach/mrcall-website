# Tracking (client-side, write-only key — safe to expose)
NEXT_PUBLIC_TRACKING_API_KEY=your-tracking-api-key

# Voice Demo — server-only credentials (never exposed to browser)
MRCALL_VOICE_BASE_URL=https://api.mrcall.ai
MRCALL_VOICE_BUSINESS_ID=your-business-id
MRCALL_VOICE_AUTH_USER=your-auth-user
MRCALL_VOICE_AUTH_PASSWORD=your-auth-password
